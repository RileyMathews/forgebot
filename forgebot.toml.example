# forgebot.toml — LEGACY EXAMPLE (for reference only)
# ====================================================
# This file shows the legacy TOML configuration format.
# NEW DEPLOYMENTS SHOULD USE ENVIRONMENT VARIABLES INSTEAD.
#
# forgebot is now configured entirely via environment variables.
# See README.md for the current environment variable reference.
#
# The format below is kept for reference when migrating existing deployments.

# ==============================================================================
# Environment Variable Mapping
# ==============================================================================
# TOML field                    → Environment Variable
# ------------------------------------------------------------------------------
# [server]
# host                          → FORGEBOT_SERVER_HOST (default: 127.0.0.1)
# port                          → FORGEBOT_SERVER_PORT (default: 8765)
# webhook_secret                → FORGEBOT_WEBHOOK_SECRET (required)
#
# [forgejo]
# url                           → FORGEBOT_FORGEJO_URL (required)
# token                         → FORGEBOT_FORGEJO_TOKEN (required)
# bot_username                  → FORGEBOT_FORGEJO_BOT_USERNAME (default: forgebot)
#
# [opencode]
# binary                        → FORGEBOT_OPENCODE_BINARY (default: opencode)
# worktree_base                 → FORGEBOT_OPENCODE_WORKTREE_BASE (default: /var/lib/forgebot/worktrees)
# config_dir                    → FORGEBOT_OPENCODE_CONFIG_DIR (default: /var/lib/forgebot/opencode-config)
#
# [database]
# path                          → FORGEBOT_DATABASE_PATH (default: /var/lib/forgebot/forgebot.db)
#
# ==============================================================================
# Legacy TOML Example (DO NOT USE FOR NEW DEPLOYMENTS)
# ==============================================================================

[server]
host = "127.0.0.1"
port = 8765
webhook_secret = "your-webhook-secret-here-change-this-in-production"

[forgejo]
url = "https://git.example.com"
token = "your-forgejo-api-token-here"
bot_username = "forgebot"

[opencode]
binary = "opencode"
worktree_base = "/var/lib/forgebot/worktrees"
config_dir = "/var/lib/forgebot/opencode-config"

[database]
path = "/var/lib/forgebot/forgebot.db"
